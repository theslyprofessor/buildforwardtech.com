---
import PageLayout from "@/layouts/PageLayout.astro";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { ServiceCard } from "@/components/react/ServiceCard";
import { SectorCard } from "@/components/react/SectorCard";
import { ContactForm } from "@/components/react/ContactForm";
import {
  SITE_CONFIG,
  SERVICES,
  AI_READINESS_PILLARS,
  AI_READINESS_DELIVERABLES,
  PORTFOLIO_SITES,
  TEAM
} from "@/lib/constants";
import { SECTORS, getTotalCompanies } from "@/lib/sectors";
import { Shield, DollarSign, Cpu, CheckCircle, ExternalLink, ArrowRight, Newspaper } from "lucide-react";
---

<PageLayout>
  <!-- Hero Section -->
  <section class="gradient-hero min-h-screen flex items-center pt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="max-w-4xl">
        <Badge variant="outline" className="mb-6">
          {SECTORS.length} Sectors &middot; {getTotalCompanies()} Companies &middot; Enterprise Experience
        </Badge>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
          <span class="gradient-text">Build Forward</span>
          <br />
          <span class="text-foreground">Into the Future</span>
        </h1>
        <p class="text-xl text-muted-foreground mb-8 max-w-2xl">
          Curating the technology sectors reshaping our world. From fusion
          energy to autonomous vehicles — we track breakthroughs, profile
          companies, and publish weekly sector intelligence. Led by Fortune
          500 veterans.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/sectors"
            class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-md font-semibold hover:bg-primary/90 transition-colors"
          >
            Explore Sectors
            <ArrowRight className="h-5 w-5" />
          </a>
          <a
            href="/newsletter"
            class="inline-flex items-center justify-center gap-2 border border-input bg-background px-8 py-4 rounded-md font-semibold hover:bg-accent hover:text-accent-foreground transition-colors"
          >
            <Newspaper className="h-5 w-5" />
            Subscribe to Newsletter
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Our Services</h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Comprehensive technology consulting to modernize, secure, and scale your business
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {SERVICES.map((service) => (
          <ServiceCard
            client:visible
            title={service.title}
            description={service.description}
            icon={service.icon}
            price={service.price}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Forward Tech Sectors Preview -->
  <section id="sectors-preview" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="accent" className="mb-4">Sector Intelligence</Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Technology That Changes Everything</h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          We track {SECTORS.length} transformative technology sectors and {getTotalCompanies()} companies
          building the future. Explore the breakthroughs reshaping civilization.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {SECTORS.slice(0, 4).map((sector) => (
          <SectorCard
            client:visible
            name={sector.name}
            slug={sector.slug}
            icon={sector.icon}
            tagline={sector.tagline}
            maturity={sector.maturity}
            companyCount={sector.companies.length}
            marketSize={sector.marketSizeEstimate}
            color={sector.color}
          />
        ))}
      </div>
      <div class="text-center mt-8">
        <a
          href="/sectors"
          class="inline-flex items-center gap-2 text-primary hover:underline font-medium"
        >
          View all {SECTORS.length} sectors
          <ArrowRight className="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- AI Readiness Package (Featured) -->
  <section id="ai-readiness" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <Badge variant="accent" className="mb-4">
            Featured Package
          </Badge>
          <h2 class="text-3xl sm:text-4xl font-bold mb-6">
            AI Readiness Assessment
          </h2>
          <p class="text-muted-foreground text-lg mb-8">
            A comprehensive evaluation of your organization's preparedness
            for AI integration. We assess your infrastructure, security posture,
            and operational workflows to create a customized roadmap.
          </p>

          <!-- Three Pillars -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
            {AI_READINESS_PILLARS.map((pillar, index) => {
              const icons = [Shield, DollarSign, Cpu];
              const Icon = icons[index];
              return (
                <div class="text-center p-4 rounded-lg bg-background">
                  <div class="inline-flex p-3 rounded-full bg-primary/10 text-primary mb-3">
                    <Icon className="h-6 w-6" />
                  </div>
                  <h3 class="font-semibold mb-2">{pillar.title}</h3>
                  <p class="text-sm text-muted-foreground">{pillar.description}</p>
                </div>
              );
            })}
          </div>

          <div class="flex items-baseline gap-2 mb-6">
            <span class="text-3xl font-bold text-primary">Starting at $1,000</span>
          </div>
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 bg-accent text-accent-foreground px-8 py-4 rounded-md font-semibold hover:bg-accent/90 transition-colors"
          >
            Get Your AI Assessment
            <ArrowRight className="h-5 w-5" />
          </a>
        </div>

        <!-- Deliverables -->
        <div class="bg-background rounded-xl p-8 border border-border">
          <h3 class="text-xl font-semibold mb-6">What You'll Receive</h3>
          <ul class="space-y-4">
            {AI_READINESS_DELIVERABLES.map((item) => (
              <li class="flex items-start gap-3">
                <CheckCircle className="h-5 w-5 text-accent shrink-0 mt-0.5" />
                <span class="text-muted-foreground">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership / About Section -->
  <section id="about" class="py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="secondary" className="mb-4">
          Leadership
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Our Team</h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Enterprise veterans delivering Fortune 500 expertise with boutique attention
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {TEAM.map((member) => (
          <div class="flex flex-col items-center text-center p-8 rounded-xl bg-card border border-border">
            <div class="w-24 h-24 rounded-full bg-gradient-to-br from-primary/20 to-accent/20 border-4 border-primary/30 flex items-center justify-center mb-6">
              <span class="text-2xl font-bold gradient-text">{member.initials}</span>
            </div>
            <h3 class="text-2xl font-bold mb-1">{member.name}</h3>
            <p class="text-lg text-primary font-semibold mb-1">{member.title}</p>
            <p class="text-sm text-accent font-medium mb-4">{member.credential}</p>
            <p class="text-muted-foreground leading-relaxed">{member.bio}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 text-primary hover:underline font-medium"
        >
          Let's discuss your project
          <ArrowRight className="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section id="portfolio" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Our Portfolio</h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          A range of projects — from full-stack platforms to small business sites — each tailored to the client's needs
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {PORTFOLIO_SITES.map((site) => (
          <a
            href={site.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col rounded-xl bg-background border border-border hover:border-primary/50 transition-all card-hover overflow-hidden"
          >
            {/* Thumbnail with gradient fallback */}
            <div class={`h-40 bg-gradient-to-br ${site.gradient} relative overflow-hidden`}>
              {site.thumbnail ? (
                <img
                  src={site.thumbnail}
                  alt={`${site.name} screenshot`}
                  class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-3xl font-bold text-foreground/20 group-hover:text-foreground/40 transition-colors tracking-wider uppercase">
                    {site.name.split(' ').map((w: string) => w[0]).join('').slice(0, 3)}
                  </span>
                </div>
              )}
            </div>
            <div class="p-5 flex flex-col flex-1">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-[10px] font-semibold uppercase tracking-wider text-primary bg-primary/10 px-2 py-0.5 rounded-full">
                  {site.tag}
                </span>
              </div>
              <div class="flex items-center justify-between mb-1">
                <h3 class="font-semibold text-foreground group-hover:text-primary transition-colors">{site.name}</h3>
                <ExternalLink className="h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors shrink-0" />
              </div>
              <p class="text-xs text-muted-foreground mb-3 leading-relaxed flex-1">
                {site.description}
              </p>
              <p class="text-[11px] text-muted-foreground/60 font-mono">
                {site.url.replace('https://', '')}
              </p>
            </div>
          </a>
        ))}

        {/* CTA Card */}
        <a
          href="#contact"
          class="group flex flex-col rounded-xl border-2 border-dashed border-border hover:border-primary/50 transition-all card-hover overflow-hidden"
        >
          <div class="h-32 bg-gradient-to-br from-primary/5 to-accent/5 flex items-center justify-center">
            <span class="text-4xl text-muted-foreground/30 group-hover:text-primary/50 transition-colors">+</span>
          </div>
          <div class="p-5 flex flex-col flex-1 items-center justify-center text-center">
            <h3 class="font-semibold text-foreground group-hover:text-primary transition-colors mb-2">Your Project Here</h3>
            <p class="text-xs text-muted-foreground leading-relaxed mb-3">
              Need a custom website, web app, or platform? Let's build something tailored to your vision.
            </p>
            <span class="inline-flex items-center gap-1 text-xs font-medium text-primary">
              Start a conversation
              <ArrowRight className="h-3 w-3" />
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <Badge variant="outline" className="mb-4">Weekly Newsletter</Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-6">
          The Future, Delivered Weekly
        </h2>
        <p class="text-muted-foreground text-lg mb-8">
          Curated breakthroughs across fusion, robotics, water tech, batteries,
          autonomous vehicles, and more. TLDR-style format — scan in 2 minutes
          or dive deep.
        </p>
        <a
          href="/newsletter"
          class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-md font-semibold hover:bg-primary/90 transition-colors"
        >
          Subscribe for Free
          <ArrowRight className="h-5 w-5" />
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <Badge variant="outline" className="mb-4">
            Get Started
          </Badge>
          <h2 class="text-3xl sm:text-4xl font-bold mb-6">
            Let's Build Forward Together
          </h2>
          <p class="text-muted-foreground text-lg mb-8">
            Ready to transform your technology strategy? Schedule a free
            30-minute consultation to discuss your goals and how we can help.
          </p>

          <div class="space-y-4 mb-8">
            <div class="flex items-center gap-3">
              <div class="p-2 rounded-lg bg-primary/10 text-primary">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <a href={`mailto:${SITE_CONFIG.email}`} class="text-foreground hover:text-primary transition-colors">
                {SITE_CONFIG.email}
              </a>
            </div>
            <div class="flex items-center gap-3">
              <div class="p-2 rounded-lg bg-primary/10 text-primary">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <a href={`tel:${SITE_CONFIG.phone.replace(/[^0-9+]/g, '')}`} class="text-foreground hover:text-primary transition-colors">
                {SITE_CONFIG.phone}
              </a>
            </div>
          </div>

          <div class="p-6 rounded-xl bg-card border border-border">
            <h3 class="font-semibold mb-2">🗓️ Book a Free 30-Minute Consultation</h3>
            <p class="text-sm text-muted-foreground">
              No commitment required. We'll discuss your challenges and
              explore how Build Forward Tech can help you achieve your goals.
            </p>
          </div>
        </div>

        <div class="bg-card rounded-xl p-8 border border-border">
          <h3 class="text-xl font-semibold mb-6">Send Us a Message</h3>
          <ContactForm client:visible />
        </div>
      </div>
    </div>
  </section>
</PageLayout>
